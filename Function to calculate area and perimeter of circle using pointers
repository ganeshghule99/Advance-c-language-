#include <stdio.h>

void circle(float r, float *area, float *peri)
{
    *area = 3.14 * r * r;
    *peri = 2 * 3.14 * r;
}

int main()
{
    float radius, area, perimeter;

    printf("Enter radius: ");
    scanf("%f", &radius);

    circle(radius, &area, &perimeter);

    printf("Area of circle = %.2f\n", area);
    printf("Perimeter of circle = %.2f\n", perimeter);

    return 0;
}
