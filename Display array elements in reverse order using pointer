#include <stdio.h>

int main()
{
    int arr[100], n, i;
    int *p;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    p = arr + n - 1;

    printf("Array in reverse order:\n");
    for(i = n; i > 0; i--)
    {
        printf("%d ", *p);
        p--;
    }

    return 0;
}
